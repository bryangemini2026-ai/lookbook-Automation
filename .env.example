# === Lookbook SNS Automation ===
# Copy to .env and edit with your values

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SQLite
SQLITE_PATH=/opt/lookbook/data/lookbook.db

# ComfyUI Servers
COMFYUI_IMAGE_URL=http://localhost:8188
COMFYUI_VIDEO_URL=http://localhost:8288

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Samba (for watcher)
SMB_USER=lookbook
SMB_PASS=

# Optional: Cloudflare R2 (future)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Optional: SNS APIs (future)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
